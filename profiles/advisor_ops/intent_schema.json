{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AdvisorIntent",
  "description": "advisor_ops 자연어 요청에서 LLM이 추출해야 할 구조화 스펙.",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "scan_all",
        "scan_profile",
        "scan_job",
        "research_tool",
        "list_recommendations",
        "dismiss_recommendation"
      ],
      "description": "수행할 동작"
    },
    "target_profile": {
      "type": "string",
      "description": "scan_profile / scan_job 액션의 대상 프로파일 ID (예: 'kk_job')",
      "maxLength": 100
    },
    "target_job": {
      "type": "string",
      "description": "scan_job 액션의 대상 잡 이름 (예: 'morning_game_jobs')",
      "maxLength": 100
    },
    "focus": {
      "type": "string",
      "enum": ["skills", "mcp", "plugins", "hooks", "model", "custom_tools", "all"],
      "default": "all",
      "description": "분석 범주"
    },
    "research_query": {
      "type": "string",
      "description": "research_tool 액션의 검색 의도 (예: 'Discord webhook MCP server alternatives')",
      "maxLength": 500
    },
    "recommendation_id": {
      "type": "string",
      "description": "dismiss_recommendation 액션의 추천 ID (memories/MEMORY.md 기록 기반)",
      "maxLength": 100
    },
    "since_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365,
      "default": 30,
      "description": "list_recommendations에서 조회할 기간(일)"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "LLM 자체 평가. 0.7 미만이면 사용자에게 재질문."
    },
    "ambiguous_fields": {
      "type": "array",
      "items": {"type": "string"},
      "description": "추출 실패한 필드명 목록"
    }
  },
  "allOf": [
    {
      "if": {"properties": {"action": {"const": "scan_profile"}}},
      "then": {"required": ["target_profile"]}
    },
    {
      "if": {"properties": {"action": {"const": "scan_job"}}},
      "then": {"required": ["target_profile", "target_job"]}
    },
    {
      "if": {"properties": {"action": {"const": "research_tool"}}},
      "then": {"required": ["research_query"]}
    },
    {
      "if": {"properties": {"action": {"const": "dismiss_recommendation"}}},
      "then": {"required": ["recommendation_id"]}
    }
  ]
}
