{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobIntent",
  "description": "사용자 자연어 요청에서 LLM이 추출해야 할 구조화 스펙. 쓰기 잡(이력서 저장, 공고 북마크)의 입력 검증에 사용.",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "search_jobs",
        "analyze_posting",
        "draft_resume",
        "update_career",
        "bookmark_posting",
        "delete_bookmark",
        "list_bookmarks",
        "generate_cover_letter"
      ],
      "description": "수행할 동작"
    },
    "query": {
      "type": "string",
      "description": "검색 질의 (search_jobs 액션)",
      "maxLength": 500
    },
    "job_title": {
      "type": "string",
      "description": "대상 직무명 (예: '백엔드 엔지니어')",
      "maxLength": 200
    },
    "company": {
      "type": "string",
      "description": "대상 회사명",
      "maxLength": 200
    },
    "posting_url": {
      "type": "string",
      "format": "uri",
      "description": "공고 URL (analyze_posting, bookmark_posting)"
    },
    "bookmark_id": {
      "type": "string",
      "description": "북마크 고유 ID (delete_bookmark)"
    },
    "resume_version": {
      "type": "string",
      "description": "이력서 버전명 (예: 'backend-2026q2')"
    },
    "skills": {
      "type": "array",
      "items": {"type": "string"},
      "maxItems": 30,
      "description": "관련 기술 스택 (필터링/매칭용)"
    },
    "experience_years": {
      "type": "integer",
      "minimum": 0,
      "maximum": 60,
      "description": "경력 연수"
    },
    "location": {
      "type": "string",
      "description": "근무 지역 (예: '서울', '원격')",
      "maxLength": 100
    },
    "salary_range": {
      "type": "object",
      "properties": {
        "min": {"type": "integer"},
        "max": {"type": "integer"},
        "currency": {"type": "string", "default": "KRW"}
      }
    },
    "deadline": {
      "type": "string",
      "format": "date-time",
      "description": "지원 마감 일시 (ISO 8601)"
    },
    "career_entry": {
      "type": "object",
      "description": "update_career 액션에서 추가/수정할 경력 항목",
      "properties": {
        "title": {"type": "string"},
        "company": {"type": "string"},
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"},
        "description": {"type": "string"},
        "achievements": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "output_format": {
      "type": "string",
      "enum": ["markdown", "docx", "pdf", "plain"],
      "default": "markdown"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "LLM 자체 평가. 0.7 미만이면 사용자에게 재질문."
    },
    "ambiguous_fields": {
      "type": "array",
      "items": {"type": "string"},
      "description": "추출 실패했거나 모호한 필드명 목록"
    }
  },
  "allOf": [
    {
      "if": {"properties": {"action": {"const": "search_jobs"}}},
      "then": {"required": ["query"]}
    },
    {
      "if": {"properties": {"action": {"const": "analyze_posting"}}},
      "then": {"required": ["posting_url"]}
    },
    {
      "if": {"properties": {"action": {"const": "bookmark_posting"}}},
      "then": {"required": ["posting_url"]}
    },
    {
      "if": {"properties": {"action": {"const": "delete_bookmark"}}},
      "then": {"required": ["bookmark_id"]}
    }
  ]
}
