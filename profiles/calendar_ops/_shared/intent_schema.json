{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CalendarIntent",
  "description": "사용자 자연어 요청에서 LLM이 추출해야 할 구조화 스펙. 쓰기 잡의 입력 검증에 사용.",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["create", "update", "delete", "read", "block"],
      "description": "수행할 동작"
    },
    "event_id": {
      "type": "string",
      "description": "update/delete 시 대상 이벤트 ID. 사용자 발화에 직접 포함되지 않으므로 조회 결과에서 해소한다."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "start": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601, 로컬 타임존 포함 (예: 2026-04-21T15:00:00+09:00)"
    },
    "end": {
      "type": "string",
      "format": "date-time"
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 5,
      "maximum": 1440,
      "description": "end 대신 사용 가능. end가 있으면 무시."
    },
    "location": {
      "type": "string",
      "maxLength": 500
    },
    "attendees": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "email"
      },
      "maxItems": 20
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "calendar_id": {
      "type": "string",
      "default": "primary"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "LLM 자체 평가. 0.7 미만이면 사용자에게 재질문."
    },
    "ambiguous_fields": {
      "type": "array",
      "items": {"type": "string"},
      "description": "추출 실패했거나 모호한 필드명 목록"
    }
  },
  "allOf": [
    {
      "if": {"properties": {"action": {"const": "create"}}},
      "then": {"required": ["title", "start"]}
    },
    {
      "if": {"properties": {"action": {"const": "update"}}},
      "then": {"required": ["event_id"]}
    },
    {
      "if": {"properties": {"action": {"const": "delete"}}},
      "then": {"required": ["event_id"]}
    }
  ]
}
