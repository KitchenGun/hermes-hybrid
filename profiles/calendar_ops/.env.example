# calendar_ops profile — environment template
# 이 파일을 `.env`로 복사한 뒤 실제 값을 채워라.
# `.env`는 gitignore되므로 리포에 커밋되지 않는다.

# ── Discord Webhook ──────────────────────────────────────────────
# 대상 채널에서 "연동 → 웹후크 → 새 웹후크" 생성 후 URL 복사
DISCORD_BRIEFING_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# 개인 DM용 (pre_meeting_reminder, conflict_detector 등)
# Discord bot 토큰 기반 → 별도 프로젝트 bot 재사용 또는 공백
DISCORD_DM_USER_ID=

# ── Google Calendar ──────────────────────────────────────────────
# 조회 대상 캘린더 ID (기본: primary)
GOOGLE_CALENDAR_ID=primary

# OAuth 자격증명 파일 경로 (프로파일 홈 기준 상대경로 또는 절대경로)
# 실제 파일은 auth.json으로 저장되며 gitignore
GOOGLE_APPLICATION_CREDENTIALS=./auth.json

# ── Locale ───────────────────────────────────────────────────────
TIMEZONE=Asia/Seoul
LOCALE=ko_KR

# ── Hermes 런타임 경로 ───────────────────────────────────────────
# bootstrap_profile.sh가 설정하는 값 (수동 변경 불필요)
# HERMES_PROFILE_HOME=/mnt/e/hermes-hybrid/profiles/calendar_ops
# HERMES_RUNTIME_HOME=/home/kang/.hermes-calendar_ops-runtime
