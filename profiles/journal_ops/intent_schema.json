{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ActivityIntent",
  "description": "사용자 자연어 활동 발화에서 추출하는 24-필드 구조. 다중 활동은 배열, 단일은 객체.",
  "oneOf": [
    { "$ref": "#/$defs/Activity" },
    {
      "type": "array",
      "items": { "$ref": "#/$defs/Activity" },
      "minItems": 1,
      "maxItems": 20
    }
  ],
  "$defs": {
    "Activity": {
      "type": "object",
      "required": ["Date", "Activity"],
      "additionalProperties": false,
      "properties": {
        "Date": {
          "type": ["string", "null"],
          "description": "ISO 날짜 (YYYY-MM-DD). 사용자가 명시하지 않으면 prompt에 주입된 [현재 날짜] 사용.",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "Weekday": {
          "type": ["string", "null"],
          "enum": [
            "Monday", "Tuesday", "Wednesday", "Thursday",
            "Friday", "Saturday", "Sunday", null
          ]
        },
        "Start Time": {
          "type": ["string", "null"],
          "description": "HH:MM 24-hour. 발화에 시각이 없으면 null.",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "End Time": {
          "type": ["string", "null"],
          "description": "HH:MM 24-hour. 종료 시각이 없으면 null.",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "Duration": {
          "type": ["integer", "null"],
          "description": "분 단위. Start와 End가 모두 있을 때만 계산.",
          "minimum": 0
        },
        "Activity": {
          "type": "string",
          "description": "활동 요약 한 줄.",
          "minLength": 1,
          "maxLength": 200
        },
        "Category": {
          "type": ["string", "null"],
          "description": "활동의 대분류. SOUL.md의 9개 enum 참조.",
          "enum": [
            "Work", "Study", "Health", "Life", "Rest",
            "Leisure", "Admin", "Social", "Other", null
          ]
        },
        "Subcategory": {
          "type": ["string", "null"],
          "description": "세부 분류 (예: Coding, Reading, Cardio).",
          "maxLength": 100
        },
        "Tags": {
          "type": ["array", "null"],
          "description": "추가 키워드 태그.",
          "items": { "type": "string" },
          "maxItems": 10
        },
        "Priority": {
          "type": ["string", "null"],
          "enum": ["High", "Medium", "Low", null]
        },
        "Focus Score": {
          "type": ["integer", "null"],
          "description": "1=거의 집중 못함 ~ 5=완전 몰입. 사용자가 명시했거나 강하게 암시한 경우만.",
          "minimum": 1,
          "maximum": 5
        },
        "Energy Score": {
          "type": ["integer", "null"],
          "description": "1=매우 피곤 ~ 5=매우 좋음.",
          "minimum": 1,
          "maximum": 5
        },
        "Difficulty": {
          "type": ["integer", "null"],
          "description": "1=매우 쉬움 ~ 5=매우 어려움.",
          "minimum": 1,
          "maximum": 5
        },
        "Deep Work": {
          "type": ["boolean", "null"],
          "description": "집중 작업이면 true, 단순 잡무/이동/휴식이면 false, 애매하면 null."
        },
        "Planned/Unplanned": {
          "type": ["string", "null"],
          "description": "사용자가 '예정', '계획', '갑자기', '즉흥' 등을 말했을 때만 판단.",
          "enum": ["Planned", "Unplanned", null]
        },
        "Outcome": {
          "type": ["string", "null"],
          "description": "결과 요약.",
          "maxLength": 500
        },
        "Notes": {
          "type": ["string", "null"],
          "description": "추가 메모, 애매한 표현 보존용.",
          "maxLength": 1000
        },
        "Location": {
          "type": ["string", "null"],
          "maxLength": 200
        },
        "Device": {
          "type": ["string", "null"],
          "enum": ["PC", "Mobile", "Tablet", "Paper", "Other", null]
        },
        "Interruptions": {
          "type": ["string", "null"],
          "description": "방해 요소.",
          "maxLength": 500
        },
        "Mood": {
          "type": ["string", "null"],
          "description": "감정 상태.",
          "maxLength": 50
        }
      }
    }
  }
}
