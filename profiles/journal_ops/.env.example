# journal_ops profile — environment template
# 이 파일을 `.env`로 복사한 뒤 실제 값을 채워라.
# `.env`는 gitignore되므로 리포에 커밋되지 않는다.
#
# 이 파일이 있어야 Hermes CLI가 OpenAI API key 등을 읽을 수 있다.
# config.yaml의 terminal.env_passthrough에 나열된 변수도 여기서 정의되어야
# 함 (post_to_sheet.py가 GOOGLE_SHEETS_WEBHOOK_URL을 보려면).

# ── OpenAI (custom provider via api.openai.com) ──────────────────
# 부모 .env의 OPENAI_API_KEY를 그대로 복사. Hermes가 gpt-4o-mini 호출에 사용.
OPENAI_API_KEY=sk-proj-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Google Sheets (Apps Script doPost endpoint) ──────────────────
# 시트 1행을 append할 webhook URL. /exec로 끝나야 함.
# 자세한 배포 절차는 README.md 참조.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# ── Optional: Discord 운영 알림 webhook ──────────────────────────
# 시트 append가 실패할 때만 발사되는 빨간색 embed.
# 없으면 비워두기 — 알림이 사일런트 no-op.
JOURNAL_ALERT_WEBHOOK_URL=

# ── Locale / Time ────────────────────────────────────────────────
TIMEZONE=Asia/Seoul
LOCALE=ko_KR
