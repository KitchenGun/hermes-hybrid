# mail_ops 계정 매핑 — 템플릿.
#
# 이 파일을 `accounts.yaml`로 복사한 뒤 본인 정보로 채우세요.
# 실제 값이 들어간 `accounts.yaml`은 .gitignore로 제외됩니다.
#
# 시크릿은 절대 평문 저장 금지:
#   - Gmail: token_file 경로만 (실제 토큰 JSON은 ./secrets/ 아래)
#   - Naver: password_env 이름만 (실제 앱 비밀번호는 .env)
#
# 시작 절차:
#   1) Google Cloud Console에서 OAuth 2.0 Desktop client JSON 다운로드
#      → ./secrets/google_oauth_client.json 으로 저장
#   2) Gmail 계정마다 항목 추가, address 본인 주소로 수정
#   3) 네이버 메일 환경설정에서 IMAP/SMTP ON, 2단계 인증 ON,
#      애플리케이션 비밀번호 발급 → .env 에 NAVER_APP_PASSWORD=...
#   4) python scripts/setup_mail_accounts.py --account <name> --auth
#   5) python scripts/setup_mail_accounts.py --list 로 모든 계정 OK 확인

accounts:
  # ── Google 계정 1 ─────────────────────────────────────────────
  - name: gmail_personal
    provider: gmail
    address: REPLACE_ME@gmail.com
    token_file: ./secrets/gmail_personal_token.json
    credentials_file: ./secrets/google_oauth_client.json

  # ── Google 계정 2 ─────────────────────────────────────────────
  - name: gmail_work
    provider: gmail
    address: REPLACE_ME@example.com
    token_file: ./secrets/gmail_work_token.json
    credentials_file: ./secrets/google_oauth_client.json

  # ── Naver 계정 ────────────────────────────────────────────────
  - name: naver_personal
    provider: naver
    address: REPLACE_ME@naver.com
    password_env: NAVER_APP_PASSWORD
