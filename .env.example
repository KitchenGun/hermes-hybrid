# Hermes-hybrid root environment template
#
# 이 파일을 ``.env`` 로 복사한 뒤 실제 값을 채워라.
# ``.env`` 는 .gitignore 로 처리되어 리포에 커밋되지 않는다.
#
# Phase 8 (2026-05-06) 구조 — 6 profile 폐기, 17 sub-agent 단일 구조.
# 자세한 변수→agent 매핑은 ``docs/AGENT_ENV.md`` 참조.

# ============================================================
# Discord Gateway (필수)
# ============================================================
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=
REQUIRE_ALLOWLIST=true

# (legacy) #일기 채널 id — forced_profile 폐기로 의미 약화. 빈 값 가능.
JOURNAL_CHANNEL_ID=0

# ============================================================
# Hermes Master Orchestrator
# ============================================================
# opencode CLI 경로 (Claude Code Max OAuth 와 동일한 $0 marginal 패턴)
HERMES_CLI_BACKEND=wsl_subprocess
HERMES_WSL_DISTRO=Ubuntu
HERMES_CLI_PATH=/home/kang/.local/bin/hermes
HERMES_HOME=/home/kang/.hermes
HERMES_TIMEOUT_MS=300000
HERMES_MAX_TURNS=20
HERMES_CONCURRENCY=3
GATEWAY_SERVICE_NAME=hermes-gateway

# Claude Code CLI (heavy path, !heavy prefix). Max OAuth 사용.
CLAUDE_CODE_CLI_PATH=/home/kang/.local/bin/claude
CLAUDE_CODE_MODEL=sonnet
CLAUDE_CODE_TIMEOUT_MS=300000
CLAUDE_CODE_CONCURRENCY=1

# ============================================================
# Ollama (local LLM, optional)
# ============================================================
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ROUTER_MODEL=llama3.2:3b
OLLAMA_WORK_MODEL=gpt-oss:20b
OLLAMA_WORKER_MODEL=gpt-oss:20b

# OpenAI SDK 호환을 위한 placeholder (Ollama 는 무시).
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:11434/v1

# ============================================================
# Discord webhooks (@devops 가 사용)
# ============================================================
# 일반 브리핑 / 알림 webhook (가장 자주 사용)
DISCORD_BRIEFING_WEBHOOK_URL=

# 메일 알림 분리 webhook (선택)
DISCORD_MAIL_WEBHOOK_URL=

# 날씨 브리핑 분리 webhook (선택)
DISCORD_WEATHER_WEBHOOK_URL=

# 잡 매칭 분리 webhook (선택)
DISCORD_KK_JOB_WEBHOOK_URL=

# DM 대상 user id (현재 미구현, 선택)
DISCORD_DM_USER_ID=

# ============================================================
# Google Sheets webhooks (@devops sheets_append)
# ============================================================
# Apps Script doPost endpoint. /exec 로 끝나야 함.
# 자세한 배포 절차: profiles/journal_ops/README.md (legacy) 참조.
GOOGLE_SHEETS_WEBHOOK_URL=
JOB_SHEETS_WEBHOOK_URL=

# 시트 append 실패 시 발사되는 운영 경보 (선택, best-effort)
JOURNAL_ALERT_WEBHOOK_URL=

# ============================================================
# Google Calendar (cocal MCP — @cocal/google-calendar-mcp)
# @researcher (read) + @devops (write) 가 사용
# ============================================================
GOOGLE_OAUTH_CREDENTIALS=
GOOGLE_CALENDAR_MCP_TOKEN_PATH=
GOOGLE_CALENDAR_ID=primary

# ============================================================
# External research (@researcher)
# ============================================================
BRAVE_SEARCH_API_KEY=

# ============================================================
# Mail (Naver IMAP)
# ============================================================
NAVER_APP_PASSWORD=

# ============================================================
# Hermes Kanban worker context (@devops auto_install)
# 보통 dispatcher 가 spawn 시 주입 — 사용자가 직접 채울 일 X.
# ============================================================
# HERMES_KANBAN_TASK=
# HERMES_KANBAN_WORKSPACE=
# HERMES_TENANT=advisor

# ============================================================
# Storage / logs
# ============================================================
STATE_DB_PATH=./data/state.db
LOG_LEVEL=INFO
LOG_JSON=false

# ============================================================
# Locale / Time
# ============================================================
TIMEZONE=Asia/Seoul
LOCALE=ko_KR
WATCHER_ENABLED=true
MAIL_SKILL_ENABLED=true

# ============================================================
# Phase rollouts (legacy — Phase 8 에서 정리 예정)
# ============================================================
# 모든 LLM 호출이 master (opencode/gpt-5.5) 통과 — 다음 토글들은 더 이상
# 효과 없음. P8.5 의 Settings 정리 commit 에서 제거됨.
# USE_HERMES_FOR_LOCAL=false
# USE_HERMES_FOR_C1=false
# USE_HERMES_FOR_HEAVY=false
# USE_HERMES_EVERYWHERE=false
# USE_NEW_JOB_FACTORY=true
# TRUST_HERMES_REFLECTION=false
# C1_BACKEND=claude_cli
# C1_CLAUDE_CODE_MODEL=haiku
# CALENDAR_SKILL_ENABLED=true
# CALENDAR_SKILL_PROFILE=calendar_ops
# CALENDAR_SKILL_PRELOAD=
# CALENDAR_SKILL_CLAUDE_MODEL=haiku
# JOURNAL_OPS_CLAUDE_MODEL=haiku

# ============================================================
# Bench / per-user (legacy, 정리 예정)
# ============================================================
# ROUTER_CONF_ACCEPT=0.75
# ROUTER_CONF_TIER_UP=0.50
# RETRY_BUDGET_DEFAULT=4
# SAME_TIER_RETRY_MAX=2
# TIER_UP_RETRY_MAX=2
# CLOUD_ESCALATION_MAX=1
# CLOUD_TOKEN_BUDGET_SESSION=20000
# CLAUDE_CALL_BUDGET_SESSION=1
# CLOUD_TOKEN_BUDGET_DAILY=100000
# SURROGATE_MAX_TOKENS_LOCAL=512
# SURROGATE_MAX_TOKENS_WORKER=1024
# PER_USER_IN_FLIGHT_MAX=1
# BENCH_JUDGE_BACKEND=claude_cli
# OLLAMA_JUDGE_MODEL=qwen3:8b
# LOCAL_FIRST_MODE=true
