# installer_ops profile — environment variable inventory (Phase 8 archive)
#
# 이 파일은 폐기된 installer_ops (Kanban worker, advisor task → install plan
# 작성) profile 이 사용하던 변수의 inventory. 값은 모두 제거됨 — 추후
# agent (@devops) 가 동일 변수를 참조할 수 있도록 변수명/용도만 보존.

# ── Hermes Kanban worker context ──────────────────────────────────────
# dispatcher 가 task spawn 시 주입했던 환경변수.
# Phase 8 후 Hermes profile cron 사라지지만, master 가 직접 Kanban worker
# 를 spawn 할 때 동일 변수명 재사용.
# 사용 agent: @devops (auto_install)
HERMES_KANBAN_TASK=
HERMES_KANBAN_WORKSPACE=
HERMES_TENANT=advisor

# ── Discord webhook ────────────────────────────────────────────────────
# install plan 결과 요약 알림
# 사용 agent: @devops (discord_notify)
DISCORD_BRIEFING_WEBHOOK_URL=

# ── Hermes runtime paths ──────────────────────────────────────────────
HERMES_RUNTIME_HOME=
HERMES_PROFILE_HOME=

# ── Locale / Time ──────────────────────────────────────────────────────
TIMEZONE=Asia/Seoul
