# mail_ops profile — environment variable inventory (Phase 8 archive)
#
# 이 파일은 폐기된 mail_ops (Gmail + Naver 메일 polling 알림) profile 이
# 사용하던 변수의 inventory. 값은 모두 제거됨 — 추후 agent (@researcher /
# @devops) 가 동일 변수를 참조할 수 있도록 변수명/용도만 보존.
#
# Note: poll 기반 mail watcher 자동화 (new_mail_alert) 는 Phase 8 에서
# 완전 폐기. 사용자가 master 한테 명시 요청 시 동일 결과 가능.

# ── Mail polling credentials ──────────────────────────────────────────
# Naver 메일 IMAP App Password
# 사용 agent: master (mail polling 시 직접 참조)
NAVER_APP_PASSWORD=

# (Gmail OAuth 토큰은 별도 secrets/ 디렉터리 또는 OAuth flow 로 관리)

# ── Discord webhook ────────────────────────────────────────────────────
# 메일 알림 전용 채널 (분리 webhook)
# 사용 agent: @devops (discord_notify)
DISCORD_MAIL_WEBHOOK_URL=

# 일반 브리핑 webhook (fallback)
DISCORD_BRIEFING_WEBHOOK_URL=

# ── Locale / Time ──────────────────────────────────────────────────────
TIMEZONE=Asia/Seoul
