# kk_job profile — environment variable inventory (Phase 8 archive)
#
# 이 파일은 폐기된 kk_job (게임 프로그래머 잡 매칭) profile 이 사용하던
# 변수의 inventory. 값은 모두 제거됨 — 추후 agent (@researcher / @devops /
# @documenter) 가 동일 변수를 참조할 수 있도록 변수명/용도만 보존.

# ── Discord webhooks ──────────────────────────────────────────────────
# 일반 브리핑 / 자소서/이력서 결과 알림
# 사용 agent: @devops (discord_notify)
DISCORD_BRIEFING_WEBHOOK_URL=

# kk_job 잡 매칭 전용 채널 (morning_game_jobs / deadline_reminder /
# weekly_job_digest / new_posting_alert 가 송신했음)
DISCORD_KK_JOB_WEBHOOK_URL=

# ── External research ──────────────────────────────────────────────────
# Brave Search API (사용 agent: @researcher web_search)
BRAVE_SEARCH_API_KEY=

# ── Career data (이력서 자료) ─────────────────────────────────────────
# kk_job 의 OAuth 자격증명 — 채용 지원 자동화 폐기로 사용처 사라짐.
# 단 사용자가 manual 수집/저장 시 참조용으로 보존.
GOOGLE_APPLICATION_CREDENTIALS=

# ── Job sheet (Apps Script doPost) ────────────────────────────────────
# morning_game_jobs 가 raw + curated 탭에 append 했던 webhook.
# 사용 agent: @devops (sheets_append, 사용자 명시 요청 시)
JOB_SHEETS_WEBHOOK_URL=

# ── Locale / Time ──────────────────────────────────────────────────────
TIMEZONE=Asia/Seoul
LOCALE=ko_KR
