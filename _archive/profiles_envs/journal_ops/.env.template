# journal_ops profile — environment variable inventory (Phase 8 archive)
#
# 이 파일은 폐기된 journal_ops profile 이 사용하던 변수의 inventory.
# 값은 모두 제거됨 — 추후 agent (@devops) 가 동일 변수를 참조할 수 있도록
# 변수명/용도만 보존.
#
# Note: forced_profile 자동화 (#일기 채널 → 24-필드 JSON 추출 → Sheets
# append) 는 Phase 8 에서 완전 폐기. 사용자가 master 한테 명시 요청 시
# 동일 결과 가능 (단, master 가 24-필드 추출 후 @devops sheets_append 호출).

# ── OpenAI (legacy direct provider) ───────────────────────────────────
# Phase 8 이후 master 가 opencode/gpt-5.5 만 사용 — 직호출 폐기.
# OPENAI_API_KEY / OPENAI_BASE_URL 은 더 이상 journal_ops 에서 필요 X.
# (Ollama base url 갱신용으로 root .env 에는 남아있을 수 있음)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# ── Google Sheets (Apps Script doPost endpoint) ───────────────────────
# 시트 1행 append 대상 webhook URL. /exec 로 끝나야 함.
# 사용 agent: @devops (sheets_append)
GOOGLE_SHEETS_WEBHOOK_URL=

# ── Optional: Discord 운영 알림 webhook ───────────────────────────────
# 시트 append 가 실패할 때만 발사되는 빨간색 embed.
# 사용 agent: @devops (sheets_append best-effort alert)
JOURNAL_ALERT_WEBHOOK_URL=

# ── Locale / Time ──────────────────────────────────────────────────────
TIMEZONE=Asia/Seoul
LOCALE=ko_KR
