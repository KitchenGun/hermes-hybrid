# calendar_ops profile — environment variable inventory (Phase 8 archive)
#
# 이 파일은 폐기된 calendar_ops profile 이 사용하던 변수의 inventory.
# 값은 모두 제거됨 — 추후 agent (특히 @researcher / @devops) 가 동일
# 변수를 참조할 수 있도록 변수명/용도만 보존.
#
# 실 값은 root .env 또는 ~/.hermes/.env 에 정의.

# ── Discord webhook ────────────────────────────────────────────────────
# 일반 브리핑 / 일정 알림 채널
# 사용 agent: @devops (discord_notify)
DISCORD_BRIEFING_WEBHOOK_URL=

# 날씨 브리핑 전용 채널 (분리 webhook)
DISCORD_WEATHER_WEBHOOK_URL=

# 개인 DM 대상 user id (pre_meeting_reminder, conflict_detector 등)
# 사용 agent: @devops (DM 송신은 미구현, webhook 주체)
DISCORD_DM_USER_ID=

# ── Google Calendar (cocal MCP @cocal/google-calendar-mcp) ─────────────
# 사용 agent:
#   @researcher — list-events / get-event (read)
#   @devops    — create-event / update-event / delete-event (write)
GOOGLE_OAUTH_CREDENTIALS=
GOOGLE_CALENDAR_MCP_TOKEN_PATH=
GOOGLE_CALENDAR_ID=primary

# ── Locale / Time ──────────────────────────────────────────────────────
TIMEZONE=Asia/Seoul
LOCALE=ko_KR
