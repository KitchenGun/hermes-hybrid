__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-linux/
.env
data/
# Bench config (prompts YAML + execution unit tests) is part of the codebase.
!data/bench/
!data/bench/**
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.log
*.log.err
logs/

# Per-machine runtime state (state DB, runtime artifacts) — repo-root only.
# Anchored with leading ``/`` so it doesn't accidentally match ``src/state/``
# (the TaskState package).
/state/

# Date-stamped backups never get committed (e.g. .env.bak.20260501,
# config.yaml.bak.20260501). 의도적 수정 전 자동 백업이라 추적 가치 없음.
*.bak.[0-9]*
.env.bak*

# Claude Code local settings (개인용, 팀 공유 settings.json은 허용)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# =====================================================================
# Growing Agent Memory Architecture — P0-A (2026-05-09).
# Replaces the Phase 14 ``data/memory/`` blanket ignore.
# Plan v4.2 makes ``data/processed_memory/`` and ``data/memory/`` part
# of the canonical / compiled memory layer. They MUST be tracked, but
# the previous ``data/`` ignore (line above) blocks them — git negation
# rules require parent unignores before child re-tracking works.
#
# WARNING: data/processed_memory/ and data/memory/ contain user
# preferences, project facts, and long-term agent memory. Track ONLY
# in private repos. For public repos, switch to skeleton-only mode in
# a follow-up PR.
# =====================================================================

# Imported raw conversations are temporary and never tracked.
data/ingest_staging/

# External memory may contain sensitive working state copied from
# Claude Code. Sanitized output can still leak context, so keep it
# untracked. Synthetic example fixtures under examples/ are OK.
data/external_memory/**
!data/external_memory/examples/
!data/external_memory/examples/**

# Parent unignores — required because line 7 ``data/`` ignored every
# child. Tracked subdirectories must be re-enabled here BEFORE any
# per-file rules below them apply.
!data/
!data/source_manifests/
!data/source_manifests/**
!data/processed_memory/
!data/processed_memory/**

# data/memory/ — option B: directory traversal allowed, but the contents
# stay ignored by default. Only the four compiled artifacts (and a
# .gitkeep placeholder for directory preservation) are explicitly
# tracked. Phase 14 user-private ``data/memory/memos.db``, CuratorJob
# ingest logs, and any auto-curated MEMORY.md backup files remain
# untracked under this rule. Order matters: ``!data/memory/`` first so
# git can traverse, then ``data/memory/**`` re-ignore, then per-file
# negations.
!data/memory/
data/memory/**
!data/memory/.gitkeep
!data/memory/USER.md
!data/memory/MEMORY.md
!data/memory/USER.manifest.json
!data/memory/MEMORY.manifest.json

# Profile-aware mode (plan-only in P0). Same gitignore policy per
# profile root; the directories themselves are not created in P0-A.
data/profiles/*/ingest_staging/
data/profiles/*/external_memory/**
!data/profiles/*/external_memory/examples/
!data/profiles/*/external_memory/examples/**

# Memory audit (rollback/export logs) — manifest-only, no raw text.
# Created by P-x scripts. Track when present.
!data/memory_audit/
!data/memory_audit/**

# Hermes profiles — secrets and runtime state
profiles/*/.env
profiles/*/auth.json
profiles/*/auth.json.bak
profiles/*/memories/
profiles/*/sessions/
profiles/*/logs/
profiles/*/.cache/

# Mail accounts — real addresses & token paths are personal.
# The .example file is the committed template.
profiles/*/accounts.yaml

# OAuth tokens, app passwords, etc. — local only.
secrets/

# 단, 디렉토리 구조 유지용 .gitkeep은 커밋 허용
!profiles/*/memories/.gitkeep
!profiles/*/sessions/.gitkeep
!profiles/*/logs/.gitkeep

# advisor_ops + installer_ops는 메타 프로파일이라 메모리(USER.md/MEMORY.md)도
# 코드의 일부 (사용자 컨텍스트 + 정책). 다른 프로파일과 달리 추적함.
!profiles/advisor_ops/memories/
!profiles/advisor_ops/memories/**
!profiles/installer_ops/memories/
!profiles/installer_ops/memories/**

# 메타 프로파일의 runtime/ 은 보고서 산출물 — 매번 갱신, 추적 안 함.
profiles/advisor_ops/runtime/
profiles/installer_ops/runtime/

# Phase 8 archive: 폐기된 profile memories — 사용자 개인 컨텍스트 (calendar_ops,
# journal_ops, kk_job, mail_ops) 는 git history 에 들어가지 않도록 ignore.
# advisor_ops + installer_ops 의 메타 컨텍스트는 _archive 안에서도 추적.
_archive/profiles_memories/calendar_ops/
_archive/profiles_memories/journal_ops/
_archive/profiles_memories/kk_job/
_archive/profiles_memories/mail_ops/

# kk_job 프로파일의 runtime/ 은 cron 산출물 — probe HTML, raw/curated JSON,
# Discord body 등 매 실행마다 갱신. skills/runtime/ 은 sheet_fallback CSV 등
# 스킬 실행 중 생성되는 임시 산출물.
profiles/kk_job/runtime/
profiles/kk_job/skills/runtime/
